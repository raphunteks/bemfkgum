<!-- ========================================================================================= -->
<!-- DIRECT DYNAMIC SEO URLs (AUTO-INDEX GENERATOR)                                            -->
<!-- Logika EJS ini akan otomatis membuat tag <url> baru setiap kali data ditambahkan di Admin -->
<!-- ========================================================================================= -->

<!-- AUTO GENERATE: BERITA / ARTIKEL E-ZINE -->
<% if (typeof articles !== 'undefined' && articles.length > 0) { %>
    <% articles.forEach(function(article) { %>
    <url>
        <loc>https://bemkbmfkgumi.com/berita?article=<%= article.Slug_URL || article.ID_Berita %></loc>
        <lastmod><%= article.Tgl_Rilis ? new Date(article.Tgl_Rilis).toISOString() : new Date().toISOString() %></lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
        <% if (article.Gambar_URL) { %>
        <image:image>
            <image:loc><%= article.Gambar_URL.replace(/&/g, '&amp;') %></image:loc>
            <image:title><%= article.Judul %></image:title>
        </image:image>
        <% } %>
    </url>
    <% }); %>
<% } %>

<!-- AUTO GENERATE: PROKER DEPARTEMEN -->
<% if (typeof prokers !== 'undefined' && prokers.length > 0) { %>
    <% prokers.forEach(function(proker) { %>
    <url>
        <loc>https://bemkbmfkgumi.com/proker-deskripsi/<%= proker.id %></loc>
        <lastmod><%= new Date().toISOString() %></lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
        <% if (proker.fotoPengurus) { %>
        <image:image>
            <image:loc><%= proker.fotoPengurus.replace(/&/g, '&amp;') %></image:loc>
            <image:title>Departemen <%= proker.dept %></image:title>
        </image:image>
        <% } %>
    </url>
    <% }); %>
<% } %>

<!-- AUTO GENERATE: KALENDER / EVENT DETAIL -->
<% if (typeof agendas !== 'undefined' && agendas.length > 0) { %>
    <% agendas.forEach(function(agenda) { %>
    <url>
        <loc>https://bemkbmfkgumi.com/proker-detail/<%= agenda.slug || agenda.id %></loc>
        <lastmod><%= agenda.tglMulai ? new Date(agenda.tglMulai).toISOString() : new Date().toISOString() %></lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
        <% if (agenda.banner) { %>
        <image:image>
            <image:loc><%= agenda.banner.replace(/&/g, '&amp;') %></image:loc>
            <image:title>Event <%= agenda.nama %></image:title>
        </image:image>
        <% } %>
    </url>
    <% }); %>
<% } %>
